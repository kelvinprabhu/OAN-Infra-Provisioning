# ── GCP staging environment — EXAMPLE ONLY ──────────────────────
# Copy to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars to Git!

gcp_project_id = "oan-gcp-staging-000000"
gcp_region     = "us-central1"
owner          = "platform-team@oan.io"
subnet_cidr    = "10.13.0.0/20"
machine_type   = "n1-standard-4"
instance_count = 3
database_tier  = "db-n1-standard-2"
db_name        = "oandb"
