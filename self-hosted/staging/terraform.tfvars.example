# ── Self-Hosted staging environment — EXAMPLE ONLY ────────────────
# Copy to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars to Git!
# Sensitive values (passwords, tokens) should come from CI/CD env vars.

vsphere_server               = "vcenter.oan.internal"
vsphere_datacenter           = "DC-OAN"
vsphere_cluster              = "CL-OAN-STAGING"
vsphere_datastore            = "DS-OAN-STAGING"
vm_template                  = "ubuntu-22-04-template"
num_cpus                     = 4
memory_mb                    = 8192
instance_count               = 1
vlan_id                      = 100
subnet_cidr                  = "192.168.4.0/24"
nfs_server                   = "nfs.oan.internal"
nfs_path                     = "/exports/oan-staging"
vault_address                = "https://vault.oan.internal:8200"
tf_backend_address           = "https://tf-backend.oan.internal/state/oan-self-hosted-staging"
owner                        = "platform-team@oan.io"
